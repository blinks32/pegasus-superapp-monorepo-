rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public access to these collections (for admin panel without auth)
    match /Blogs/{blogId} {
      allow read, write: if true;
    }
    
    match /products/{productId} {
      allow read, write: if true;
    }
    
    // Keep existing rules for other collections
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/Admins/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Admins collection
    match /Admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(adminId) || isAdmin();
    }
    
    // Riders collection
    match /Riders/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Drivers collection
    match /Drivers/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Other collections - keep existing rules
    match /Request/{requestId} {
      allow create, read, update, delete: if isAuthenticated();
    }
    
    match /RideHistory/{historyId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}